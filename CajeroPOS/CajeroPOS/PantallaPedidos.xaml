<Window x:Class="CajeroPOS.PantallaPedidos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pedidos"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"  Icon="/frente-de-la-tienda.ico"
        Background="{DynamicResource BgBrush}">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- EN PREPARACIÓN -->
        <!-- ===================== -->
        <Border Grid.Column="0"
                Background="{DynamicResource PanelBrush}"
                CornerRadius="10"
                Padding="15"
                Margin="5">

            <StackPanel>

                <TextBlock Text="EN PREPARACIÓN"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="Red"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <ItemsControl x:Name="lstPreparacion">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#22000000"
                                    CornerRadius="8"
                                    Margin="5"
                                    Padding="10">

                                <TextBlock Text="{Binding}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Center"/>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </Border>

        <!-- ===================== -->
        <!-- LISTOS -->
        <!-- ===================== -->
        <Border Grid.Column="1"
                Background="{DynamicResource PanelBrush}"
                CornerRadius="10"
                Padding="15"
                Margin="5">

            <StackPanel>

                <TextBlock Text="LISTOS"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="LimeGreen"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <ItemsControl x:Name="lstListos">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#22000000"
                                    CornerRadius="8"
                                    Margin="5"
                                    Padding="10">

                                <TextBlock Text="{Binding}"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Center"/>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </Border>

    </Grid>
</Window>