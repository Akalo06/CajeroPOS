<Window x:Class="CajeroPOS.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inicio de Sesión"
        Height="420" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}" ResizeMode="NoResize"  Icon="/frente-de-la-tienda.ico">

    <Grid>

        <!-- Panel centrado -->
        <Border Width="370"
                Padding="25"
                Background="{DynamicResource PanelBrush}"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center" Height="347">

            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Bienvenido"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Usuario -->
                <TextBlock Text="Usuario"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,5"/>

                <TextBox x:Name="txtUsuario"
                         Height="35"
                         FontSize="14"
                         Padding="5"
                         Background="{DynamicResource BgBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource AccentBrush}"/>

                <!-- Contraseña -->
                <TextBlock Text="Contraseña"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,15,0,5"/>

                <PasswordBox x:Name="txtPassword"
                             Height="35"
                             FontSize="14"
                             Padding="5"
                             Background="{DynamicResource BgBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource AccentBrush}"/>

                <!-- Botón -->
                <Button Content="Ingresar"
                        Height="40"
                        Margin="0,20,0,0"
                        FontSize="16"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Click="BtnIngresar_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>